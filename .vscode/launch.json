    "version": "0.2.0",
    "configurations": [
        {
            "name": "dr_copilot",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "dr_copilot (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "dr_copilot (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        },
        // for web chrome on port 3000
        {
            "name": "dr_copilot (web)",
            "request": "launch",
            "type": "dart",
            "args": [
                "--web-port=3000"
            ],
        },
        {
            "name": "dr_copilot (doppler)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "toolArgs": [],
            "args": [],
            "env": {
                "DOPPLER_RUN": "doppler run --"
            },
            "preLaunchTask": "doppler-run"
        },
    ]
}