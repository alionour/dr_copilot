{
  "name": "dr-copilot-notification-backend",
  "version": "1.0.0",
  "description": "AWS Lambda function for sending push notifications via Firebase Cloud Messaging",
  "main": "index.js",
  "scripts": {
    "install-deps": "npm install",
    "package": "zip -r function.zip index.js node_modules package.json",
    "package-windows": "powershell Compress-Archive -Path index.js,node_modules,package.json -DestinationPath function.zip -Force"
  },
  "keywords": [
    "aws",
    "lambda",
    "fcm",
    "firebase",
    "push-notifications",
    "dr-copilot"
  ],
  "author": "dr_copilot",
  "license": "MIT",
  "dependencies": {
    "firebase-admin": "^12.0.0"
  }
}
