# Environment Variables Template for Backend Deployment
# Copy this file to .env and fill in the values

# --- Firebase Service Account ---
# Get this from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# The JSON file needs to be converted to a single-line string
# Example: {"type":"service_account","project_id":"your-project",...}
FIREBASE_SERVICE_ACCOUNT=

# --- Amazon SES ---
# The email address you have verified in Amazon SES (us-east-1 region)
# You need to verify this in AWS Console > Amazon SES > Verified Identities
SES_FROM_EMAIL=

# --- Application URL ---
# The public URL of your application (used for links in emails)
# Example: https://app.drcopilot.ai or http://localhost:3000 for testing
APP_URL=
